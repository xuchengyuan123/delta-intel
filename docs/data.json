  "guides": {
    "intro": "从零上手《三角洲行动》。内容分模块组织，每个模块下是要点卡片。数据随官方版本更新，以游戏内为准。",
    "modules": [
      {
        "title": "入门准备",
        "icon": "🎒",
        "cards": [
          {
            "title": "选对干员",
            "text": "新手首选全能突击红狼（T0，开荒稳）；组排必带蜂医续航，露娜/骇爪拿信息。"
          },
          {
            "title": "先赚钱再开图",
            "text": "特勤处挑「小时利润」高的产物刷钱（见特勤处产物），别一上来就硬刚。"
          },
          {
            "title": "安全箱规则",
            "text": "放进安全箱的物资阵亡不掉落，贵重品优先塞安全箱再撤离。"
          },
          {
            "title": "看懂任务区域",
            "text": "标「烽火地带」的任务要去烽火地带完成，排位/攻防不统计进度。"
          }
        ]
      },
      {
        "title": "地图与搜刮",
        "icon": "🗺️",
        "cards": [
          {
            "title": "胸挂怎么选",
            "text": "突击位轻型 6 槽；搜索位重型 10 槽；医疗位多医疗槽。"
          },
          {
            "title": "钥匙房在哪",
            "text": "行政楼、控制中心、金库、狱长办公室产出高价值物资/文件。"
          },
          {
            "title": "散落物资点",
            "text": "非钥匙房自然刷新点，跑图顺路就能舔，不抢不卡。"
          },
          {
            "title": "容器产出",
            "text": "工具箱/武器箱/医疗箱/电子箱各有固定产出，见「实用工具」。"
          }
        ]
      },
      {
        "title": "养成路线",
        "icon": "🏭",
        "cards": [
          {
            "title": "特勤处升级",
            "text": "1→2(5万)…4→5(80万) 解锁全部设施，越高越省材料。"
          },
          {
            "title": "扩容箱",
            "text": "小型 +10 / 中型 +20 / 大型 +40 格，仓库不够再买。"
          },
          {
            "title": "瞄具挑选",
            "text": "近战红点/全息，中远 2x/4x，远距 8x；按枪械射程配。"
          },
          {
            "title": "洗消舱（AZ3）",
            "text": "新赛季针对辐射机制，提升辐射耐受与消退速度。"
          }
        ]
      },
      {
        "title": "战斗要点",
        "icon": "⚔️",
        "cards": [
          {
            "title": "常见敌人",
            "text": "游荡者 / 精英兵 / BOSS（钢铁、渡鸦等），注意血量与护甲。"
          },
          {
            "title": "周常可叠加",
            "text": "进度跨对局累加，不用单局硬扛，几局凑满即可。"
          },
          {
            "title": "撤离技巧",
            "text": "部分撤离点需等待倒计时或携带道具，提前占位别急。"
          },
          {
            "title": "资源循环",
            "text": "舔包→卖交易行→买改件→再战，形成正循环。"
          }
        ]
      }
    ]
  },
