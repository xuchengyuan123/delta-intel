  "trivia": [
    {
      "id": "t1",
      "title": "撤离点机制",
      "body": "每个地图有固定撤离点，部分需要满足条件（如倒计时等待、携带指定道具）才会开启。",
      "tag": "机制"
    },
    {
      "id": "t2",
      "title": "每日密码门",
      "body": "地图中的密码门每天刷新密码，可在本站「每日地图密码」查看当日密码。",
      "tag": "小技巧"
    },
    {
      "id": "t3",
      "title": "特勤处小时利润",
      "body": "特勤处制作产物的「小时利润」= 总利润 ÷ 单件耗时 × 60，挑耗时短的更划算。",
